# Скопируйте в application-prod.properties и задайте переменные окружения на хостинге.
# Файл application-prod.properties не коммитится (.gitignore).

spring.application.name=crm-system
spring.thymeleaf.cache=true

server.servlet.session.timeout=3d
server.servlet.session.cookie.max-age=3d
server.servlet.session.cookie.http-only=true
server.servlet.session.cookie.secure=true
server.servlet.session.cookie.same-site=lax
server.forward-headers-strategy=framework

spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USER}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.open-in-view=false
spring.sql.init.mode=never

spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=50MB

file.upload-dir=uploads
app.storage.type=${APP_STORAGE_TYPE:supabase}
supabase.storage.url=${SUPABASE_STORAGE_URL}
supabase.storage.service-role-key=${SUPABASE_SERVICE_ROLE_KEY}
supabase.storage.bucket=${SUPABASE_BUCKET:crm-uploads}

spring.web.error.include-message=never
spring.web.error.include-stacktrace=never

# Первый деплой — выключите после создания админа
app.bootstrap.default-super-admin.enabled=${BOOTSTRAP_SUPER_ADMIN_ENABLED:false}
app.bootstrap.default-super-admin.login=${BOOTSTRAP_SUPER_ADMIN_LOGIN}
app.bootstrap.default-super-admin.password=${BOOTSTRAP_SUPER_ADMIN_PASSWORD}
